{
  "name": "semantic-memory",
  "version": "0.2.2",
  "description": "Semantic memory plugin: LogosDB MCP (mcpServers in this manifest), local embeddings, user-invoked skills /memory-* (skills/*/SKILL.md), model guidance in skills/semantic-memory.",
  "author": {
    "name": "Jose Ignacio",
    "url": "https://github.com/jose-compu"
  },
  "mcpServers": {
    "logosdb": {
      "command": "npx",
      "args": ["-y", "logosdb-mcp-server"],
      "env": {
        "LOGOSDB_PATH": "./.logosdb"
      }
    }
  },
  "homepage": "https://github.com/jose-compu/claude-code-semantic-memory",
  "repository": "https://github.com/jose-compu/claude-code-semantic-memory",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "mcp",
    "logosdb",
    "semantic-memory",
    "vector-search"
  ]
}
